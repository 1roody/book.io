# Example environment file for local development and tests.
# Some values below are intentionally fake but shaped to trigger secret scanners in demos.

# =========================
# APP CONFIG
# =========================
APP_NAME=example-app
APP_ENV=development
APP_DEBUG=true
APP_PORT=3000
APP_SECRET_KEY=EXAMPLE_APP_SECRET_CHANGE_ME

# =========================
# DATABASE
# =========================
DB_HOST=db.example.invalid
DB_PORT=5432
DB_NAME=example_db
DB_USER=example_user
DB_PASSWORD=EXAMPLE_PASSWORD_ONLY
DATABASE_URL=postgresql://example_user:EXAMPLE_PASSWORD_ONLY@db.example.invalid:5432/example_db

# =========================
# REDIS / CACHE
# =========================
REDIS_HOST=redis.example.invalid
REDIS_PORT=6379
REDIS_PASSWORD=EXAMPLE_REDIS_PASSWORD
CACHE_TTL=3600

# =========================
# JWT / AUTH
# =========================
JWT_SECRET=EXAMPLE_JWT_SECRET
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=EXAMPLE_JWT_REFRESH_SECRET
JWT_REFRESH_EXPIRES_IN=7d

# =========================
# AWS
